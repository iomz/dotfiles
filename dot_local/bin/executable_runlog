#!/usr/bin/env zsh

unsetopt BG_NICE

log=$(mktemp "${TMPDIR:-/tmp}/ai-run.XXXXXX")
print -r -- "log: $log"

"$@" >"$log" 2>&1 &
pid=$!

for _ in {1..20}; do
    kill -0 "$pid" 2>/dev/null || break
    sleep 1
done

if kill -0 "$pid" 2>/dev/null; then
    kill "$pid"
    print -r -- "timeout: 20s"
    tail -n 80 "$log"
    exit 124
fi

wait "$pid"
exit_status=$?
print -r -- "exit: $exit_status"
tail -n 80 "$log"
exit "$exit_status"

#!/bin/sh
set -eu

if [ -z "${BW_SESSION:-}" ]; then
    printf '%s\n' 'BW_SESSION is not set.' >&2
    printf '%s\n' 'Run: export BW_SESSION="$(bw unlock --raw)"' >&2
    exit 1
fi

bw get item 'b56e4567-a662-48e3-b2fb-b46b00a935bb' \
    | jq -er '.fields[]? | select(.name == "ansible-vault-password") | .value' \
    | tr -d '\r\n'

printf '\n'

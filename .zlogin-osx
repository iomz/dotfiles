# Aliases for OSX
alias ls='ls -CFG'
alias diff='colordiff'
alias kess='less -R'

# LANG for OSX
#export LC_ALL=C
export LC_CTYPE=UTF-8
export LANG=en_US.UTF-8

# Python
export PYTHONPATH=/usr/local/lib/python2.7/site-packages

# UpTeX bin PATH
#export PATH="/Applications/UpTeX.app/teTeX/bin:$PATH"

# mactex path
eval `/usr/libexec/path_helper -s`

# Add Homebrew PATHs
export HOMEBREW_PREFIX=/usr/local/Cellar
export PATH=/usr/local/bin:/usr/local/sbin:$PATH
## Install applications via brew-cask into /Applications
export HOMEBREW_CASK_OPTS="--appdir=/Applications"
## homebrew-kde tap
#export KDEDIRS=$KDEDIRS:$HOME/Library/Preferences/KDE:/usr/local/kde4
#export PATH=$PATH:/usr/local/kde4/bin
#export DYLD_LIBRARY_PATH=/usr/local/kde4/lib:$DYLD_LIBRARY_PATH
#launchctl setenv DYLD_LIBRARY_PATH /usr/local/kde4/lib:$DYLD_LIBRARY_PATH
#export XDG_DATA_HOME=$HOME/Library/Preferences/KDE/share
#export XDG_DATA_DIRS=/usr/local/kde4/share:/usr/local/share:/usr/share

# golang enviromental set up
export GOPATH=$HOME/go
export GOROOT=/usr/local/opt/go/libexec
export PATH=$GOPATH/bin:$GOROOT/bin:$PATH

# Android Studio
export STUDIO_JDK=/Library/Java/JavaVirtualMachines/jdk1.8.0_25.jdk
export ANDROID_SDK=$HOME/Library/Android/sdk/platform-tools
export PATH=$ANDROID_SDK:$PATH

# Maven => defined from dotfiles/Environment.app
#export M2_HOME="/usr/local/Cellar/maven/3.3.1/libexec"
#export M2="/usr/local/Cellar/maven/3.3.1/libexec/bin"

# Catalina
export CATALINA_HOME=/opt/apache-tomcat-8.0.22

# Add RVM to PATH for scripting
export PATH=$PATH:$HOME/.rvm/bin

# Load RVM into a shell session *as a function*
[[ -s "$HOME/.rvm/scripts/rvm" ]] && source "$HOME/.rvm/scripts/rvm" 

# Home bin
export PATH=$HOME/bin:$PATH


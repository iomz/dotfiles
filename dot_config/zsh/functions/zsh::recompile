#autoload

# cd ${0%/*}

zdir=$ZDOTDIR
[[ -d $zdir ]] || zdir=${XDG_CONFIG_HOME}/zsh
ZDOTDIR=$zdir

# Refresh commands list from PATH in current shell
rehash

_zsh_compile_if_writable() {
    local target=$1
    # Avoid noisy zcompile failures in readonly or sandboxed startup contexts.
    [[ -s $target && -w ${target:h} ]] || return
    zcompile $target
}

_zsh_compile_if_writable ~/.zshenv
_zsh_compile_if_writable ~/.zprofile

# Combine zshrc components into one file
lst=()
lst+=($zdir/rc.d/*)
lst+=($zdir/.zshrc $zdir/.zlogin $zdir/functions/*)
lst=(${^lst}(N-.))
# Compile the combined zwc only when the config directory is writable.
if [[ -n $lst && -w $zdir ]]; then
    zcompile ${lst[@]}
fi

# Compile the completion dump
zcd=$zdir/.zcompdump
if [[ -s $zcd && -w ${zcd:h} && (! -s ${zcd}.zwc || $zcd -nt ${zcd}.zwc) ]]; then zcompile $zcd; fi

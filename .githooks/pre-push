#!/bin/sh
set -eu

repo_root=$(git rev-parse --show-toplevel)
files=$(mktemp "${TMPDIR:-/tmp}/chezmoi-secretlint.XXXXXX")
trap 'rm -f "$files"' EXIT HUP INT TERM

zero=0000000000000000000000000000000000000000
while read -r local_ref local_sha remote_ref remote_sha; do
    if [ "$local_sha" = "$zero" ]; then
        continue
    fi

    if [ "$remote_sha" = "$zero" ]; then
        git ls-tree -r --name-only -z "$local_sha" >> "$files"
    else
        git diff --name-only --diff-filter=ACMR -z "$remote_sha..$local_sha" >> "$files"
    fi
done

if [ ! -s "$files" ]; then
    exit 0
fi

cd "$repo_root"
sort -zu "$files" | xargs -0 ./node_modules/.bin/secretlint --secretlintignore .secretlintignore --

{{ if and (eq .chezmoi.os "linux") (or (eq .chezmoi.arch "aarch64") (eq .chezmoi.arch "arm64")) -}}
#!/bin/sh
set -eu

sudo apt update
sudo apt install -y \
  git \
  curl \
  ca-certificates \
  gnupg \
  dirmngr \
  gawk \
  build-essential \
  pkg-config \
  libssl-dev \
  zlib1g-dev \
  libbz2-dev \
  libreadline-dev \
  libsqlite3-dev \
  libncursesw5-dev \
  xz-utils \
  tk-dev \
  libxml2-dev \
  libxmlsec1-dev \
  libffi-dev \
  liblzma-dev \
  extrepo

if ! command -v mise >/dev/null 2>&1; then
  sudo extrepo enable mise
  sudo apt update
  sudo apt install -y mise
fi

{{ else if eq .chezmoi.os "linux" -}}
#!/bin/sh
set -eu

sudo apt update
sudo apt install -y \
  git \
  curl \
  ca-certificates \
  chafa \
  gnupg \
  dirmngr \
  gawk \
  build-essential \
  pkg-config \
  libssl-dev \
  zlib1g-dev \
  libbz2-dev \
  libreadline-dev \
  libsqlite3-dev \
  libncursesw5-dev \
  xz-utils \
  tk-dev \
  libxml2-dev \
  libxmlsec1-dev \
  libffi-dev \
  liblzma-dev \
  linux-headers-$(uname -r) \
  extrepo

if ! command -v mise >/dev/null 2>&1; then
  sudo extrepo enable mise
  sudo apt update
  sudo apt install -y mise
fi

{{ else if eq .chezmoi.os "darwin" -}}
#!/bin/sh
set -eu

# Core packages required to bootstrap or maintain this dotfiles environment.
brew install \
  ca-certificates \
  cmake \
  coreutils \
  git \
  gnu-sed \
  gnu-getopt \
  gpg \
  gawk \
  jq \
  mise \
  openssl \
  pkg-config \
  readline \
  sqlite3 \
  tcl-tk \
  xz \
  zlib

# Daily convenience CLIs managed by Homebrew.
brew install \
  bat \
  bat-extras \
  delta \
  duf \
  dust \
  eza \
  hyperfine \
  trash \
  watch \
  wget \

# Specialized tools that are useful on this host but not part of the core bootstrap.
brew install \
  act \
  antigravity-cli \
  chafa \
  goreleaser
{{ end -}}

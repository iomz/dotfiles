#!/usr/bin/env zsh

skip_global_compinit=1

# uncomment to analyze init time
#ENABLE_ZPROFTIME=true

# set ZDOTDIR
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"

# extended globbing
setopt EXTENDED_GLOB
# don't source /etc/z*
setopt NO_GLOBAL_RCS

(( ${+TERM} )) || export TERM="xterm-256color"; COLORTERM="truecolor"
(( ${+USER} )) || export USER="${USERNAME}"
(( ${+XDG_CACHE_HOME} )) || export XDG_CACHE_HOME="${HOME}/.cache"
(( ${+XDG_CONFIG_HOME} )) || export XDG_CONFIG_HOME="${HOME}/.config"
(( ${+XDG_DATA_HOME} )) || export XDG_DATA_HOME="${HOME}/.local/share"

# Mirror the only current .profile-managed shell option without sourcing .profile
# for every zsh process.
if [[ -z "${TINY_CHEZMOI}" && "$(uname -s)" == "Linux" ]]; then
    case "$(uname -m)" in
        aarch64|arm64) export TINY_CHEZMOI=1 ;;
    esac
fi

# Program options
export \
    ANSIBLE_SCP_IF_SSH=y \
    COMPOSE_DOCKER_CLI_BUILD=1 \
    CORRECT_IGNORE="*zinit[-]*" \
    DISABLE_MAGIC_FUNCTIONS=1 \
    DOCKER_BUILDKIT=1 \
    GTAGSLABEL=pygments \
    HOMEBREW_NO_{ENV_HINTS,INSTALL_CLEANUP}=1 \
    OBJC_DISABLE_INITIALIZE_FORK_SAFETY=YES \
    RIPGREP_CONFIG_PATH=${XDG_CONFIG_HOME}/ripgrep/config \
    SHELL_SESSIONS_DISABLE=1
